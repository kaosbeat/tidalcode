--- grondvonk
---  billionaire barbie ballerina
p "midiclock" $ n "1" # s "[reaperclock]"
-- # record clock into reaperclock as notes
-- # Then run the action "SWS/BR: Create project markers from notes in selected MIDI items". 



hush

setcps (135/60/4)

codeview 2


do
  hydramode 3
  codeview 5
  p5view 5
  camview 2
  cubes
  cube1
  d1 $ fast "<1`>"  -- <2 1 2> 
    $ n "2(<3>,8)" -- <3 5>
    # s "[popkick, midi]"
    # gain 1
    # room 0.1
    # midichan 1

d1 silence

-- d1 $ slow 2 $ s "bd sn [bd!2 sn bd] sn"

do
  d2 $ fast 1
    -- $ s "[hh*2] ~  ~  ~ cpu ~ cpu ~"  
    $ s "[hh*<2 4>] ~  ~  cpu cpu*2 ~ cpu ~"
    # vowel "a _ i a"
    # gain 1
    # room 0.8
    # sz 0.1
  m1 $ ccn "5*4" # ccv " 10 50 2 20" # s "midi" # midichan 1

m2 $ ccn "7*4" # ccv "2 1" # s "midi" # midichan 1


cube3

hydramode 1

do
  let pat ="a a b c d e [f e] ~"
  d4 $ slow 2 
    $ n pat
    # s "[ultrasaw, midi]"
    # gain 0.7
    # legato 0.5
    # ccn 65 # ccv (irand 180) |* pat 


do
  hydramode 2
  d5 $ degradeBy ("^9") $ slow 2 
    $ n (off "<0.125 0.06125>" (|+ "[12, 19]") 
      "[e c] ~ [c5 f4] ~ c~ [d e] a")
    # legato 1
    # amp "0.4 0.9"
    # s "bal"



do 
  d3 $ degradeBy "^7" 
    $ loopAt 4 
    $ slow 1
    $ slice 8 ("1(16,16)" |> (irand "[^i15]") + "[^i23]")
    -- $ slice 16 ("1(8,8)" |> (irand "8") + "1")
    $ n "<8 2 4 6>*8"
    -- $ n "9*8"
    # s "[brkcoreloops, midi]"
    # midichan 2
    # legato ("[^31]*0.75"+0.25)
    # gain 1.2
  lines


hush


d4 silence

-----  4D  topological  change vectors

do
  -- hush
  d8 $ slow 4
    $ degradeBy "[^12]"
    $ striate "^d28"
    -- $ n "0 1 2 3 4 5 6 7"
    $ n "0(8,8)" |> (irand "^d20")
    # s "4D"
    # room "[^20]"
    # size 0.6
    # krush "[^i36]"
    # gain 0.9
  


do
  hydramode 5
  codeview 2
  camview 3
  cubes
  cube3
  d1 $ slow 1
    $ n "4(4,8)"
    # s "[hardkick, midi]"
    # gain 0.8
    # room 0.1 # sz 0.2
    # lpf ("[^13]"*100 + 100)
    # lpq (0.4*"^21")
    # midichan 1





do
  d5 
    $ degradeBy "[^9]" 
    $ fast 0.5
    -- $ press
    $ every 2 ghost
    $ n (off 0.25 (|+| 19) "[~ d6] <[~ a5] [~ b5]> <[~ g5] [~ e5]>  <[~ ~ e5 g5] ~ ~>")
-- $ n (off 0.125 (|+| "12") -- "cs6 as5 as5 <[e5 g5] ~ ~>")
    # s "md2"  --- surgeXT agroculture
    # gain 1



do  --- this turns of 4D 
  hydramode 7
  codeview 2
  camview 2
  p5view 5
  cubes
  cube1  
  d8 $ degradeBy  "[^12]" $ slow 4 
    $ n "1*8" |> (irand 8) 
    # s "rave" 
    # midichan 1

do
  cubes
  cube2
  d1 $ n "2(<4 8>,8)"
    # s "[midi, clubkick]"
    # midichan 1
    # legato 0.5
    # room 0.2
    # lpf 400


startrot

hush


do
  hydramode 16
  -- resetCycles
  let pat0 = "g e g d"
  let pat1 = "e a a e"
  let pat2 = " e b a g"
  let pat = pat1
  d4 
    $ degradeBy "^8"
    $ slow 2
    $ select "[^16]" [n pat, n pat0, n pat1, n pat2]
    $ ply "<2 2 >"
    -- $ n (off 0.125 (|+| 12 ) pat)
    -- $ n pat
    # s "op3"
    # octave 3
    # legato "<0.5 1 0.75 0.5>"

d5 silence

do
  d6 $ fast 1
    $ n  (off 0.125 (|-| "<5 -7>")
      "[~ <d6 e5 g5 a5>]!4")
    # s "md2"


d6 silence

d3 silence

d6 $ slow 1
  $ n  "a d [f a]*2 ~"
  # s "op3"
  # octave 3

do 
  rects
  hydramode 18


d3 $ fast 4 
  $ n "<2 1 5> <~ ~> < 5 2 >~"
  # legato 3
  # s "[op3, midi]" --C2
  # midichan 2

startrot 

hydramode 6


--- sitar?


do
