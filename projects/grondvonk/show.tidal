    $ slice "<8>" "5 5 5 5"
    -- $ slice "8" "5 5 5 5"
    -- $ slice 8 "5 5 5 5"
    $ s "[sitar]"
    # legato 0.5
    # gain 1.2



d6 silence

do
  rects
  rect2
  let pat0 = "1 1 1 1"
  let pat1 = "1 <~ 1 1*[^i21]> <1 1 1*4> <~ 1>"
  let pat2 = "1 <~ 1> 1 ~"
  let pat3 = "<1*4 1*8 1*2> 1(5,8) 1*8 1(3,8)"
  let pat = pat0
  d1 $ slow 1 
    -- $ select ((irand 4)/4) [n pat0, n pat1, n pat2, n pat3]
    $ select ("[^13]") [n pat0, n pat1, n pat2, n pat3]
    -- $ n pat
    # s "[tabla:21, gabba, midi]"  -- oncL --*/---
    # legato 1
    # room 0.4
    # sz 0.3
    # midichan 7



hush

do
  lines
  let pat0 = "4*4 <14 4> <14 7*4 14*8> [6 6*16]"
  let pat1 = "4 <14*2 4> <14 7 [6 14]> [6 6]"
  let pat2 = "4*8 <14*4 4*8> <[14*8 6*4]  [7*4 4] [14 8]> [6 6]"
  let pat3 = "4 <14 4> <14 7 14> [6 6]"
  d2 
    $ every 2 (|+| speed "0.5") 
    $ every 3 (0.5 <~)
    $ whenmod 8 6 (rev)
    $ select ("[^14]") [n pat0, n pat1, n pat2, n pat3]
    -- # legato 2
    -- $ cat []
    # s"[tabla, midi]"  
    # midichan 5



do
  let choppat0 = "<16 [16 32] [8 0] [0 4] 32>"
  let choppat1 = "<2 <[0 4] <[4 32]>> [2 8] 16>"
  let choppat2 = "<2 <[8 4] <[4 16]>> [2 8] 16>"
  let choppat3 = "<32>"
  let pat0 = "<0 3 2 1>"
  let pat1 = "<0*8 3*4 2*6 1*4>" |> (irand 8)
  let pat2 = "<0>"
  let pat3 = "<0*8>"
  d4 $ slow 1
     $ selectF ("[^24]") [chop choppat0, chop choppat1, chop choppat2, chop choppat3]
     $ select ("[^16]") [n pat0, n pat1, n pat2, n pat3]
    -- $ chop choppat0
    $ jux rev
    -- $ n "<0*8 3*4 2*6 1*4>" |> (irand 8) 
    -- $ n "<0 3 2 1>"
    # s "sitar"
    # squiz 1
    # legato 0.4
    # room 0.2
    # gain 1

hush

